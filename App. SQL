-- =====================================================
-- DATA API GRANTS
-- =====================================================
-- RLS policies alone are not enough. Grants and RLS are two separate gates:
-- a GRANT decides whether a Postgres role can reach a table via the Data
-- API (what supabase-js actually calls) at all; RLS then decides which
-- rows it can see once it's through. Supabase used to auto-grant
-- SELECT/INSERT/UPDATE/DELETE to anon/authenticated/service_role on every
-- new public-schema table, but that default is going away — new projects
-- created after May 30, 2026 don't get it, and it stops applying to *any*
-- newly created table, on *any* project, from October 30, 2026 onward.
-- These explicit grants make the schema correct regardless of when the
-- project was created or when this file is run.
--
-- No table here grants anything to `anon` — every feature in this app
-- requires a signed-in user, so unauthenticated access is intentionally
-- not exposed at all.

GRANT SELECT, INSERT, UPDATE ON students TO authenticated;
GRANT SELECT ON courses TO authenticated;
GRANT INSERT, UPDATE, DELETE ON courses TO authenticated; -- narrowed to admins only by the RLS policies above
GRANT SELECT ON units TO authenticated;
GRANT INSERT, UPDATE, DELETE ON units TO authenticated;   -- narrowed to admins only by the RLS policies above
GRANT SELECT, INSERT, UPDATE ON enrollments TO authenticated;
GRANT SELECT, INSERT ON feedback TO authenticated;

GRANT ALL ON students, courses, units, enrollments, feedback TO service_role;
